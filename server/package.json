{
  "name": "sim-bat-server",
  "version": "1.0.0",
  "private": true,
  "description": "API REST SIM-BAT — gestion BTP",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "build:render": "node scripts/schema-postgres.js && prisma generate --schema=prisma/schema.postgres.prisma && prisma db push --schema=prisma/schema.postgres.prisma --skip-generate && tsc -p tsconfig.json",
    "start:render": "node dist/src/initialiser.js && node dist/src/index.js",
    "seed": "tsx prisma/seed.ts",
    "reinitialiser": "tsx prisma/reinitialiser.ts",
    "migrate": "prisma migrate dev",
    "test": "vitest run"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/pdfkit": "^0.13.5",
    "@types/swagger-ui-express": "^4.1.7",
    "prisma": "^6.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
